generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  Int              @id @default(autoincrement())
  email               String           @unique
  username            String           @unique
  password            String
  deletedAt           DateTime?
  tenantId            String?
  createdAt           DateTime         @default(now())
  failedLoginAttempts Int              @default(0)
  lockUntil           DateTime?
  roleId              Int?
  status              UserStatus       @default(ACTIVE)
  updatedAt           DateTime         @default(now()) @updatedAt
  tokenVersion        Int              @default(0)
  refreshTokens       RefreshToken[]
  role                Role?            @relation(fields: [roleId], references: [id])
  userPermissions     UserPermission[]

  @@unique([tenantId, email])
  @@index([tenantId, username])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([email])
  @@index([deletedAt])
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  parentId    Int?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  parent      Role?            @relation("RoleHierarchy", fields: [parentId], references: [id])
  children    Role[]           @relation("RoleHierarchy")
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  roles       RolePermission[]
  users       UserPermission[]
}

model RolePermission {
  roleId       Int
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserPermission {
  userId       Int
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  action      String
  entity      String
  entityId    Int
  userId      Int?
  details     Json?
  createdAt   DateTime @default(now())
  tenantId    String
  version     Int      @default(1)
  operationId String?  @unique

  @@index([tenantId])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  revoked   Boolean  @default(false)
  deviceId  String?
   user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
   @@index([userId])
 }

model TokenRevocation {
  id        Int      @id @default(autoincrement())
  jti       String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Student {
  studentId         Int                 @id @default(autoincrement())
  firstName         String
  lastName          String
  dateOfBirth       DateTime
  gender            String
  address           String?
  parentId          Int
  code              String              @unique
  health            String?
  dateCreate        DateTime            @default(now())
  dateModif         DateTime            @updatedAt
  lieuOfBirth       String?
  bloodType         String?
  etatCivil         String?
  cid               String?
  nationality       String?
  observation       String?
  numNumerisation   String?
  dateInscription   DateTime
  okBlock           Boolean             @default(false)
  photoFileName     String?
  lastModifiedBy    Int?
  operationId       String?             @unique
  tenantId          String
  version           Int                 @default(1)
  email             String?
  phone             String?
  fees              Fee[]
  payments          Payment[]
  studentAttendance StudentAttendance[]
  riskProfile       StudentRiskProfile?
  compte            Compte?
  studentClasses    StudentClass[]
  parent            Parent              @relation(fields: [parentId], references: [parentId], onDelete: Cascade)

  @@index([tenantId, lastName, firstName])
  @@index([tenantId, code])
  @@index([tenantId, parentId])
  @@index([tenantId, gender])
  @@index([tenantId, dateCreate])
  @@map("students")
}

model Parent {
  parentId     Int       @id @default(autoincrement())
  father       String?
  mother       String?
  fatherJob    String?
  motherJob    String?
  fatherNumber String?
  motherNumber String?
  operationId  String?   @unique
  tenantId     String
  version      Int       @default(1)
  students     Student[]

  @@index([tenantId])
  @@map("parents")
}

model Local {
  localId       Int             @id @default(autoincrement())
  name          String
  code          String          @unique
  dateCreate    DateTime?
  dateModif     DateTime?
  NumClass      Int?
  size          Int             @default(0)
  operationId   String?         @unique
  tenantId      String
  version       Int             @default(1)
  weeklyHours   Int             @default(6)
  classes       classes[]
  subject_local subject_local[]

  @@index([tenantId])
}

model classes {
  classId           Int                 @id @default(autoincrement())
  ClassName         String
  code              String              @unique
  dateCreate        DateTime?
  dateModif         DateTime?
  NumStudent        Int
  localId           Int
  okBlock           String              @default("N")
  cloture           Boolean             @default(false)
  operationId       String?             @unique
  tenantId          String
  version           Int                 @default(1)
  translations      ClassTranslation[]
  fees              Fee[]
  studentAttendance StudentAttendance[]
  TeacherCalsses    TeaherClass[]
  Timetables        Timetable[]
  local             Local               @relation(fields: [localId], references: [localId])
  studentClasses    StudentClass[]

  @@index([tenantId])
}

model ClassTranslation {
  id      Int     @id @default(autoincrement())
  classId Int
  locale  String
  name    String
  class   classes @relation(fields: [classId], references: [classId], onDelete: Cascade)

  @@unique([classId, locale])
}

model subject {
  subjectId       Int                  @id @default(autoincrement())
  subjectName     String
  totalGrads      Float
  parentId        Int
  BG              Int
  BD              Int
  level           Int?
  dateCreate      DateTime?
  dateModif       DateTime?
  okBlock         Boolean              @default(false)
  operationId     String?              @unique
  tenantId        String
  version         Int                  @default(1)
  coff            Float                @default(1)
  translations    SubjectTranslation[]
  Teachersubjects TeacherSubject[]
  Timetables      Timetable[]
  grads           Grads[]
  parent          subject              @relation("SubjectToParent", fields: [parentId], references: [subjectId])
  children        subject[]            @relation("SubjectToParent")
  subject_local   subject_local[]

  @@index([tenantId])
}

model SubjectTranslation {
  id        Int     @id @default(autoincrement())
  subjectId Int
  locale    String
  name      String
  subject   subject @relation(fields: [subjectId], references: [subjectId], onDelete: Cascade)

  @@unique([subjectId, locale])
}

model parameter {
  paramId     Int     @id @default(autoincrement())
  paramName   String  @unique
  okActive    Boolean @default(false)
  operationId String? @unique
  paramValue  String?
  tenantId    String?
  version     Int     @default(1)

  @@index([tenantId])
}

model subject_local {
  subjectLocalId Int       @id @default(autoincrement())
  subjectId      Int
  localId        Int
  cloture        Boolean   @default(false)
  dateCreate     DateTime?
  dateModif      DateTime?
  operationId    String?   @unique
  tenantId       String?
  version        Int       @default(1)
  local          Local     @relation(fields: [localId], references: [localId])
  subject        subject   @relation(fields: [subjectId], references: [subjectId])

  @@unique([subjectId, localId])
  @@index([tenantId])
}

model StudentClass {
  id           Int        @id @default(autoincrement())
  studentId    Int
  classId      Int
  isCurrent    Boolean    @default(false)
  cloture      Boolean    @default(false)
  schoolYearId Int
  operationId  String?    @unique
  tenantId     String?
  version      Int        @default(1)
  grads        Grads[]
  Class        classes    @relation(fields: [classId], references: [classId])
  schoolYear   SchoolYear @relation(fields: [schoolYearId], references: [id])
  Student      Student    @relation(fields: [studentId], references: [studentId])

  @@unique([studentId, schoolYearId])
  @@index([tenantId])
  @@map("student_classes")
}

model SchoolYear {
  id             Int            @id @default(autoincrement())
  year           String         @unique
  startDate      DateTime
  endDate        DateTime
  isCurrent      Boolean        @default(false)
  operationId    String?        @unique
  tenantId       String
  version        Int            @default(1)
  semesters      Semester[]
  studentClasses StudentClass[]

  @@index([tenantId])
  @@map("school_years")
}

model Semester {
  id             Int        @id @default(autoincrement())
  name           String
  startDate      DateTime
  endDate        DateTime
  academicYearId Int
  tenantId       String
  version        Int        @default(1)
  operationId    String?    @unique
  exams          Exam[]
  schoolYear     SchoolYear @relation(fields: [academicYearId], references: [id])

  @@index([tenantId])
}

model Employer {
  employerId         Int                  @id @default(autoincrement())
  firstName          String
  lastName           String
  dateOfBirth        DateTime
  lieuOfBirth        String?
  gender             String
  address            String?
  fatherName         String?
  motherName         String?
  code               String               @unique
  health             String?
  dateCreate         DateTime?
  dateModif          DateTime?
  bloodType          String?
  etatCivil          String?
  cid                String?
  nationality        String?
  observation        String?
  numNumerisation    String?
  dateInscription    DateTime?
  okBlock            Boolean              @default(false)
  type               String
  photoFileName      String?
  phone              String?
  weeklyWorkload     Int                  @default(20)
  checkInTime        String?              @default("08:00")
  checkOutTime       String?              @default("16:00")
  operationId        String?              @unique
  salary             Decimal              @default(0) @db.Decimal(10, 2)
  salaryBasis        String               @default("DAILY")
  tenantId           String
  version            Int                  @default(1)
  email              String?
  employerAttendance EmployerAttendance[]
  payments           Payment[]
  payroll            Payroll[]
  teacherEvaluations TeacherEvaluation[]
  Teachersubjects    TeacherSubject[]
  TeacherCalsses     TeaherClass?
  Timetables         Timetable[]
  compte             Compte?

  @@index([tenantId])
  @@map("employers")
}

model TeaherClass {
  id          Int      @id @default(autoincrement())
  employerId  Int      @unique
  classId     Int
  isCurrent   Boolean  @default(false)
  operationId String?  @unique
  tenantId    String
  version     Int      @default(1)
  Class       classes  @relation(fields: [classId], references: [classId])
  Employer    Employer @relation(fields: [employerId], references: [employerId])

  @@index([tenantId])
}

model TeacherSubject {
  id          Int      @id @default(autoincrement())
  employerId  Int
  subjectId   Int
  isCurrent   Boolean  @default(false)
  operationId String?  @unique
  tenantId    String
  version     Int      @default(1)
  Employer    Employer @relation(fields: [employerId], references: [employerId])
  subject     subject  @relation(fields: [subjectId], references: [subjectId])

  @@unique([employerId, subjectId])
  @@index([tenantId])
}

model TimeSlot {
  id          Int         @id @default(autoincrement())
  label       String
  startTime   String
  endTime     String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  operationId String?     @unique
  tenantId    String
  version     Int         @default(1)
  Timetables  Timetable[]

  @@index([tenantId])
}

model Timetable {
  id                  Int           @id @default(autoincrement())
  day                 String
  classId             Int
  subjectId           Int
  timeSlotId          Int
  employerId          Int?
  academicYear        String
  operationId         String?       @unique
  tenantId            String
  version             Int           @default(1)
  aiGeneratedAt       DateTime?
  aiOptimizationScore Float?
  mode                TimetableMode @default(MANUAL)
  Class               classes       @relation(fields: [classId], references: [classId])
  teacher             Employer?     @relation(fields: [employerId], references: [employerId])
  subject             subject       @relation(fields: [subjectId], references: [subjectId])
  timeSlot            TimeSlot      @relation(fields: [timeSlotId], references: [id])

  @@unique([day, timeSlotId, classId, academicYear])
  @@index([tenantId])
}

model StudentAttendance {
  id           Int              @id @default(autoincrement())
  studentId    Int
  classId      Int
  date         DateTime         @default(now())
  status       AttendanceStatus @default(ABSENT)
  academicYear String
  operationId  String?          @unique
  tenantId     String
  version      Int              @default(1)
  class        classes          @relation(fields: [classId], references: [classId])
  student      Student          @relation(fields: [studentId], references: [studentId])

  @@unique([studentId, date, academicYear])
  @@index([tenantId, date, status])
  @@index([tenantId, classId, date])
}

model EmployerAttendance {
  id           Int              @id @default(autoincrement())
  employerId   Int
  date         DateTime         @default(now())
  checkInTime  DateTime?
  checkOutTime DateTime?
  status       AttendanceStatus @default(ABSENT)
  remarks      String?
  academicYear String
  lateMinutes  Int?             @default(0)
  operationId  String?          @unique
  tenantId     String
  version      Int              @default(1)
  employer     Employer         @relation(fields: [employerId], references: [employerId])

  @@unique([employerId, date, academicYear])
  @@index([tenantId, date, status])
}

model Exam {
  id          Int       @id @default(autoincrement())
  examName    String
  dateStart   DateTime
  dateEnd     DateTime
  dateCreate  DateTime?
  dateModif   DateTime?
  publish     Boolean
  operationId String?   @unique
  tenantId    String
  version     Int       @default(1)
  semesterId  Int?
  semester    Semester? @relation(fields: [semesterId], references: [id])
  grads       Grads[]

  @@index([tenantId])
}

model Grads {
  id             Int          @id @default(autoincrement())
  grads          Float
  dateCreate     DateTime?    @default(now())
  dateModif      DateTime?    @updatedAt
  examId         Int
  studentClassId Int
  subjectId      Int
  operationId    String?      @unique
  tenantId       String
  version        Int          @default(1)
  exam           Exam         @relation(fields: [examId], references: [id])
  studentClass   StudentClass @relation(fields: [studentClassId], references: [id])
  subject        subject      @relation(fields: [subjectId], references: [subjectId])

  @@unique([examId, studentClassId, subjectId])
  @@index([tenantId])
  @@map("grads")
}

model Compte {
  id                Int                 @id @default(autoincrement())
  name              String
  parentId          Int
  BG                Int
  BD                Int
  level             Int?
  dateCreate        DateTime?           @default(now())
  dateModif         DateTime?           @updatedAt
  isPosted          Boolean             @default(false)
  employerId        Int?                @unique
  studentId         Int?                @unique
  category          CompteCategory      @default(GENERAL)
  code              String?             @unique
  isFeeCash         Boolean             @default(false)
  nameAr            String?
  nature            AccountNature       @default(ASSET)
  operationId       String?             @unique
  selectionCode     String?
  showInParent      Boolean             @default(true)
  tenantId          String
  version           Int                 @default(1)
  translations      CompteTranslation[]
  expenses          Expense[]
  fees              Fee[]
  journalEntryLines JournalLine[]
  paymentsDest      Payment[]           @relation("PaymentDest")
  payments          Payment[]
  paymentsSource    Payment[]           @relation("PaymentSource")
  payrolls          Payroll[]
  employer          Employer?           @relation(fields: [employerId], references: [employerId])
  parent            Compte              @relation("CompteToParent", fields: [parentId], references: [id])
  children          Compte[]            @relation("CompteToParent")
  student           Student?            @relation(fields: [studentId], references: [studentId])

  @@index([tenantId, code])
  @@index([tenantId, category])
  @@map("comptes")
}

model CompteTranslation {
  id       Int    @id @default(autoincrement())
  compteId Int
  locale   String
  name     String
  compte   Compte @relation(fields: [compteId], references: [id], onDelete: Cascade)

  @@unique([compteId, locale])
}

model Fee {
  id                    Int       @id @default(autoincrement())
  title                 String
  amount                Decimal   @default(0) @db.Decimal(15, 2)
  dueDate               DateTime
  classId               Int?
  studentId             Int?
  description           String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  compteId              Int?
  dateEndConsommation   DateTime?
  dateStartConsommation DateTime?
  operationId           String?   @unique
  tenantId              String
  version               Int       @default(1)
  class                 classes?  @relation(fields: [classId], references: [classId])
  compte                Compte?   @relation(fields: [compteId], references: [id])
  student               Student?  @relation(fields: [studentId], references: [studentId])
  payments              Payment[]

  @@index([tenantId])
}

model Payroll {
  id                Int           @id @default(autoincrement())
  employerId        Int
  period_start      DateTime
  period_end        DateTime
  baseSalary        Decimal       @db.Decimal(10, 2)
  allowances        Decimal       @default(0) @db.Decimal(10, 2)
  deductions        Decimal       @default(0) @db.Decimal(10, 2)
  netSalary         Decimal       @db.Decimal(10, 2)
  status            PayrollStatus @default(DRAFT)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  attendanceSummary Json?
  compteId          Int?
  operationId       String?       @unique
  tenantId          String
  version           Int           @default(1)
  compte            Compte?       @relation(fields: [compteId], references: [id])
  employer          Employer      @relation(fields: [employerId], references: [employerId])

  @@index([tenantId])
}

model Expense {
  id                    Int       @id @default(autoincrement())
  title                 String
  category              String
  amount                Decimal   @db.Decimal(10, 2)
  expenseDate           DateTime
  description           String?
  isPaid                Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  compteId              Int?
  dateEndConsommation   DateTime?
  dateStartConsommation DateTime?
  isAmortization        Boolean   @default(false)
  operationId           String?   @unique
  tenantId              String
  version               Int       @default(1)
  compte                Compte?   @relation(fields: [compteId], references: [id])
  payments              Payment[]

  @@index([tenantId])
}

model Payment {
  id             Int           @id @default(autoincrement())
  feeId          Int?
  amount         Decimal       @default(0) @db.Decimal(15, 2)
  date           DateTime      @default(now())
  method         PaymentMethod @default(CASH)
  status         PaymentStatus @default(COMPLETED)
  transactionId  String?
  description    String?
  studentId      Int?
  employerId     Int?
  compteId       Int?
  expenseId      Int?
  compteDestId   Int?
  compteSourceId Int?
  operationId    String?       @unique
  tenantId       String
  version        Int           @default(1)
  compteDest     Compte?       @relation("PaymentDest", fields: [compteDestId], references: [id])
  compte         Compte?       @relation(fields: [compteId], references: [id])
  compteSource   Compte?       @relation("PaymentSource", fields: [compteSourceId], references: [id])
  employer       Employer?     @relation(fields: [employerId], references: [employerId])
  expense        Expense?      @relation(fields: [expenseId], references: [id])
  fee            Fee?          @relation(fields: [feeId], references: [id])
  student        Student?      @relation(fields: [studentId], references: [studentId])

  @@index([tenantId, status, date])
  @@index([tenantId, studentId, date])
  @@index([tenantId, date])
  @@index([studentId])
  @@index([employerId])
}

model Journal {
  id          Int            @id @default(autoincrement())
  code        String         @unique
  name        String
  type        JournalType
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  createdBy   Int
  operationId String?        @unique
  tenantId    String
  version     Int            @default(1)
  entries     JournalEntry[]

  @@index([tenantId])
  @@map("journals")
}

model JournalEntry {
  id            Int                @id @default(autoincrement())
  journalId     Int
  entryNumber   String             @unique
  date          DateTime           @default(now())
  referenceType String?
  referenceId   Int?
  description   String?
  totalDebit    Decimal            @default(0) @db.Decimal(15, 2)
  totalCredit   Decimal            @default(0) @db.Decimal(15, 2)
  status        JournalEntryStatus @default(DRAFT)
  createdAt     DateTime           @default(now())
  postedAt      DateTime?
  createdBy     Int
  postedBy      Int?
  operationId   String?            @unique
  tenantId      String
  version       Int                @default(1)
  journal       Journal            @relation(fields: [journalId], references: [id])
  lines         JournalLine[]

  @@index([date])
  @@index([tenantId])
}

model JournalLine {
  id          Int          @id @default(autoincrement())
  entryId     Int
  compteId    Int
  lineNumber  Int
  debit       Decimal      @default(0) @db.Decimal(15, 2)
  credit      Decimal      @default(0) @db.Decimal(15, 2)
  description String?
  operationId String?      @unique
  tenantId    String
  version     Int          @default(1)
  compte      Compte       @relation(fields: [compteId], references: [id])
  entry       JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([compteId])
  @@index([tenantId])
}

model FiscalYear {
  id        Int      @id @default(autoincrement())
  year      String   @unique
  startDate DateTime
  endDate   DateTime
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenantId    String
  version     Int      @default(1)
  operationId String?  @unique
  isPublic    Boolean  @default(true)

  @@index([tenantId])
  @@map("events")
}

model StudentRiskProfile {
  id                 Int       @id @default(autoincrement())
  studentId          Int       @unique
  attendance         Float     @default(0)
  averageGrade       Float     @default(0)
  behaviorScore      Float     @default(0)
  homeworkCompletion Float     @default(0)
  riskLevel          RiskLevel @default(LOW)
  recommendation     String?
  lastCalculatedAt   DateTime  @default(now())
  tenantId           String
  version            Int       @default(1)
  operationId        String?   @unique
  student            Student   @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@index([tenantId])
}

model TeacherEvaluation {
  id                     Int      @id @default(autoincrement())
  teacherId              Int
  score                  Float
  improvementProbability Float
  weakAreas              String[]
  trainingPlan           String[]
  createdAt              DateTime @default(now())
  tenantId               String
  teacher                Employer @relation(fields: [teacherId], references: [employerId])

  @@index([teacherId])
  @@index([tenantId])
}

model SystemSettings {
  id           Int     @id @default(autoincrement())
  weekStartDay WeekDay @default(SUNDAY)
  firstHour    String  @default("08:00")
  lastHour     String  @default("16:00")
  slotDuration Int     @default(60)
  tenantId     String  @unique
  version      Int     @default(1)
  operationId  String? @unique

  @@index([tenantId])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum PayrollStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  REVERSED
  CANCELLED
}

enum AccountNature {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum JournalType {
  CASH
  BANK
  PAYROLL
  GENERAL
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  ONLINE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum CompteCategory {
  GENERAL
  CAISSE
  BANQUE
  RECETTE
  DEPENSE
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum TimetableMode {
  MANUAL
  AI_GENERATED
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  domain    String   @unique
  plan      Plan     @default(STARTER)
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id            String             @id @default(uuid())
  tenantId      String
  plan          Plan
  billingPeriod BillingPeriod
  status        SubscriptionStatus
  startDate     DateTime
  endDate       DateTime
  autoRenew     Boolean            @default(true)
  price         Int // Store in DZD
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  history       SubscriptionHistory[]

  @@index([tenantId])
}

model SubscriptionHistory {
  id             String        @id @default(uuid())
  subscriptionId String
  event          String
  plan           Plan
  billingPeriod  BillingPeriod
  changedAt      DateTime      @default(now())
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
}

enum Plan {
  STARTER
  PRO
  ENTERPRISE
}

enum BillingPeriod {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  EXPIRED
  SUSPENDED
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}
