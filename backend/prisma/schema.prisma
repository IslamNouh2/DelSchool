generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int               @id @default(autoincrement())
  email                 String            @unique
  username              String            @unique
  password              String
  roleId                Int?
  role                  Role?             @relation(fields: [roleId], references: [id])
  status                UserStatus        @default(ACTIVE)
  failedLoginAttempts  Int               @default(0)
  lockUntil             DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @default(now()) @updatedAt
  tenantId              String?
  refreshTokens         RefreshToken[]
  userPermissions       UserPermission[]
  deletedAt             DateTime?
}

model Role {
  id            Int              @id @default(autoincrement())
  name          String           @unique
  description   String?
  parentId      Int?
  parent        Role?            @relation("RoleHierarchy", fields: [parentId], references: [id])
  children      Role[]           @relation("RoleHierarchy")
  users         User[]
  permissions   RolePermission[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Permission {
  id          Int              @id @default(autoincrement())
  name        String           @unique // e.g., "user:create"
  description String?
  roles       RolePermission[]
  users       UserPermission[]
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@id([roleId, permissionId])
}

model UserPermission {
  userId       Int
  permissionId Int
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@id([userId, permissionId])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}


model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String   // CREATE, UPDATE, DELETE
  entity    String   // Student, User, etc.
  entityId  Int
  userId    Int?
  details   Json?
  createdAt DateTime @default(now())
  
  tenantId    String
  version     Int      @default(1)
  operationId String?  @unique

  @@index([tenantId])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  revoked   Boolean  @default(false)
  deviceId  String?
}

model TokenRevocation {
  id        Int      @id @default(autoincrement())
  jti       String   @unique // JWT ID
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Student {
  studentId         Int                 @id @default(autoincrement())
  firstName         String
  lastName          String
  dateOfBirth       DateTime
  gender            String
  address           String?
  parentId          Int
  code              String              @unique
  health            String?
  dateCreate        DateTime            @default(now())
  dateModif         DateTime            @updatedAt
  lieuOfBirth       String?
  bloodType         String?
  etatCivil         String?
  cid               String?
  nationality       String?
  observation       String?
  numNumerisation   String?
  dateInscription   DateTime
  okBlock           Boolean             @default(false)
  photoFileName     String?
  email             String?
  phone             String?
  
  // Sync & Multi-tenancy
  tenantId          String
  version           Int                 @default(1)
  operationId       String?             @unique
  lastModifiedBy    Int?

  fees              Fee[]
  payments          Payment[]
  studentAttendance StudentAttendance[]
  compte            Compte?
  studentClasses    StudentClass[]
  parent            Parent              @relation(fields: [parentId], references: [parentId], onDelete: Cascade)
  riskProfile       StudentRiskProfile?

  @@map("students")
  @@index([firstName, lastName])
  @@index([parentId])
  @@index([tenantId])
}

model Parent {
  parentId     Int       @id @default(autoincrement())
  father       String?
  mother       String?
  fatherJob    String?
  motherJob    String?
  fatherNumber String?
  motherNumber String?
  
  tenantId     String
  version      Int       @default(1)
  operationId  String?   @unique

  students     Student[]

  @@map("parents")
  @@index([tenantId])
}

model Local {
  localId       Int             @id @default(autoincrement())
  name          String
  code          String          @unique
  dateCreate    DateTime?
  dateModif     DateTime?
  NumClass      Int?
  size          Int             @default(0)
  weeklyHours   Int             @default(6)  // حجم الساعي الأسبوعي

  tenantId      String
  version       Int             @default(1)
  operationId   String?         @unique

  classes       classes[]
  subject_local subject_local[]

  @@index([tenantId])
}

model classes {
  classId           Int                 @id @default(autoincrement())
  ClassName         String
  code              String              @unique
  dateCreate        DateTime?
  dateModif         DateTime?
  NumStudent        Int
  localId           Int
  okBlock           String              @default("N")
  cloture           Boolean             @default(false)

  tenantId          String
  version           Int                 @default(1)
  operationId       String?             @unique

  fees              Fee[]
  studentAttendance StudentAttendance[]
  TeacherCalsses    TeaherClass[]
  Timetables        Timetable[]
  local             Local               @relation(fields: [localId], references: [localId])
  studentClasses    StudentClass[]
  translations      ClassTranslation[]

  @@index([tenantId])
}

model ClassTranslation {
  id        Int      @id @default(autoincrement())
  classId   Int
  locale    String
  name      String
  class     classes  @relation(fields: [classId], references: [classId], onDelete: Cascade)

  @@unique([classId, locale])
}

model subject {
  subjectId       Int              @id @default(autoincrement())
  subjectName     String
  totalGrads      Float
  parentId        Int
  BG              Int
  BD              Int
  level           Int?
  dateCreate      DateTime?
  dateModif       DateTime?
  okBlock         Boolean          @default(false)

  tenantId        String
  version         Int              @default(1)
  operationId     String?          @unique

  Teachersubjects TeacherSubject[]
  Timetables      Timetable[]
  grads           Grads[]
  parent          subject          @relation("SubjectToParent", fields: [parentId], references: [subjectId])
  children        subject[]        @relation("SubjectToParent")
  subject_local   subject_local[]
  translations    SubjectTranslation[]

  @@index([tenantId])
}

model SubjectTranslation {
  id        Int      @id @default(autoincrement())
  subjectId Int
  locale    String   // 'en', 'ar', 'fr'
  name      String
  subject   subject  @relation(fields: [subjectId], references: [subjectId], onDelete: Cascade)

  @@unique([subjectId, locale])
}

model parameter {
  paramId   Int     @id @default(autoincrement())
  paramName String  @unique
  okActive  Boolean @default(false)
  paramValue String? // Extended for non-boolean settings

  tenantId    String?   // Optional for global settings, but mostly per tenant
  version     Int       @default(1)
  operationId String?   @unique

  @@index([tenantId])
}

model subject_local {
  subjectLocalId Int       @id @default(autoincrement())
  subjectId      Int
  localId        Int
  cloture        Boolean   @default(false)
  dateCreate     DateTime?
  dateModif      DateTime?

  tenantId       String?
  version        Int       @default(1)
  operationId    String?   @unique

  local          Local     @relation(fields: [localId], references: [localId])
  subject        subject   @relation(fields: [subjectId], references: [subjectId])

  @@unique([subjectId, localId])
  @@index([tenantId])
}

model StudentClass {
  id           Int        @id @default(autoincrement())
  studentId    Int
  classId      Int
  isCurrent    Boolean    @default(false)
  cloture      Boolean    @default(false)
  schoolYearId Int
  grads        Grads[]
  Class        classes    @relation(fields: [classId], references: [classId])
  schoolYear   SchoolYear @relation(fields: [schoolYearId], references: [id])
  Student      Student    @relation(fields: [studentId], references: [studentId])

  tenantId    String?
  version     Int        @default(1)
  operationId String?    @unique

  @@unique([studentId, schoolYearId])
  @@map("student_classes")
  @@index([tenantId])
}

model SchoolYear {
  id             Int            @id @default(autoincrement())
  year           String         @unique
  startDate      DateTime
  endDate        DateTime
  isCurrent      Boolean        @default(false)

  tenantId       String
  version        Int            @default(1)
  operationId    String?        @unique

  studentClasses StudentClass[]

  @@map("school_years")
  @@index([tenantId])
}

model Employer {
  employerId         Int                  @id @default(autoincrement())
  firstName          String
  lastName           String
  dateOfBirth        DateTime
  lieuOfBirth        String?
  gender             String
  address            String?
  fatherName         String?
  motherName         String?
  code               String               @unique
  health             String?
  dateCreate         DateTime?
  dateModif          DateTime?
  bloodType          String?
  etatCivil          String?
  cid                String?
  nationality        String?
  observation        String?
  numNumerisation    String?
  dateInscription    DateTime?
  okBlock            Boolean              @default(false)
  type               String
  photoFileName      String?
  phone              String?
  email              String?
  weeklyWorkload     Int                  @default(20)
  salary             Decimal              @default(0) @db.Decimal(10, 2)
  salaryBasis        String               @default("DAILY") // DAILY or HOURLY
  checkInTime        String?              @default("08:00")
  checkOutTime       String?              @default("16:00")

  tenantId           String
  version            Int                  @default(1)
  operationId        String?              @unique

  employerAttendance EmployerAttendance[]
  payments           Payment[]
  payroll            Payroll[]
  Teachersubjects    TeacherSubject[]
  TeacherCalsses     TeaherClass?
  Timetables         Timetable[]
  compte             Compte?
  teacherEvaluations TeacherEvaluation[]

  @@map("employers")
  @@index([tenantId])
}

model TeaherClass {
  id         Int      @id @default(autoincrement())
  employerId Int      @unique
  classId    Int
  isCurrent  Boolean  @default(false)

  tenantId   String
  version    Int      @default(1)
  operationId String? @unique

  Class      classes  @relation(fields: [classId], references: [classId])
  Employer   Employer @relation(fields: [employerId], references: [employerId])

  @@index([tenantId])
}

model TeacherSubject {
  id         Int      @id @default(autoincrement())
  employerId Int
  subjectId  Int
  isCurrent  Boolean  @default(false)

  tenantId   String
  version    Int      @default(1)
  operationId String? @unique

  Employer   Employer @relation(fields: [employerId], references: [employerId])
  subject    subject  @relation(fields: [subjectId], references: [subjectId])

  @@unique([employerId, subjectId])
  @@index([tenantId])
}

model TimeSlot {
  id         Int         @id @default(autoincrement())
  label      String
  startTime  String
  endTime    String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  tenantId   String
  version    Int         @default(1)
  operationId String?    @unique

  Timetables Timetable[]

  @@index([tenantId])
}

model Timetable {
  id           Int       @id @default(autoincrement())
  day          String
  classId      Int
  subjectId    Int
  timeSlotId   Int
  employerId   Int?
  academicYear String

  tenantId     String
  version      Int       @default(1)
  operationId  String?   @unique

  mode                TimetableMode @default(MANUAL)
  aiOptimizationScore Float?
  aiGeneratedAt       DateTime?

  Class        classes   @relation(fields: [classId], references: [classId])
  teacher      Employer? @relation(fields: [employerId], references: [employerId])
  subject      subject   @relation(fields: [subjectId], references: [subjectId])
  timeSlot     TimeSlot  @relation(fields: [timeSlotId], references: [id])

  @@unique([day, timeSlotId, classId, academicYear])
  @@index([tenantId])
}

model StudentAttendance {
  id           Int              @id @default(autoincrement())
  studentId    Int
  classId      Int
  date         DateTime         @default(now())
  status       AttendanceStatus @default(ABSENT)
  academicYear String

  tenantId     String
  version      Int              @default(1)
  operationId  String?          @unique

  class        classes          @relation(fields: [classId], references: [classId])
  student      Student          @relation(fields: [studentId], references: [studentId])

  @@unique([studentId, date, academicYear])
  @@index([tenantId])
}

model EmployerAttendance {
  id           Int              @id @default(autoincrement())
  employerId   Int
  date         DateTime         @default(now())
  checkInTime  DateTime?
  checkOutTime DateTime?
  status       AttendanceStatus @default(ABSENT)
  remarks      String?
  lateMinutes  Int?             @default(0)
  academicYear String

  tenantId     String
  version      Int              @default(1)
  operationId  String?          @unique

  employer     Employer         @relation(fields: [employerId], references: [employerId])

  @@unique([employerId, date, academicYear])
  @@index([tenantId])
}

model Exam {
  id         Int       @id @default(autoincrement())
  examName   String
  dateStart  DateTime
  dateEnd    DateTime
  dateCreate DateTime?
  dateModif  DateTime?
  publish    Boolean

  tenantId   String
  version    Int       @default(1)
  operationId String?    @unique

  grads      Grads[]

  @@index([tenantId])
}

model Grads {
  id             Int          @id @default(autoincrement())
  studentClassId Int
  subjectId      Int
  examId         Int
  grads          Float
  dateCreate     DateTime?    @default(now())
  dateModif      DateTime?    @updatedAt

  tenantId       String
  version        Int          @default(1)
  operationId    String?      @unique

  exam           Exam         @relation(fields: [examId], references: [id])
  studentClass   StudentClass @relation(fields: [studentClassId], references: [id])
  subject        subject      @relation(fields: [subjectId], references: [subjectId])

  @@unique([examId, studentClassId, subjectId])
  @@map("grads")
  @@index([tenantId])
}

model Compte {
  id                Int            @id @default(autoincrement())
  name              String
  parentId          Int
  BG                Int
  BD                Int
  level             Int?
  dateCreate        DateTime?      @default(now())
  dateModif         DateTime?      @updatedAt
  isPosted          Boolean        @default(false)
  employerId        Int?           @unique
  studentId         Int?           @unique
  code              String?        @unique
  nameAr            String? // Kept for backward compatibility but marked for migration
  selectionCode     String?
  isFeeCash         Boolean        @default(false)
  showInParent      Boolean        @default(true)
  nature            AccountNature  @default(ASSET)
  category          CompteCategory @default(GENERAL)

  tenantId          String
  version           Int            @default(1)
  operationId       String?        @unique

  fees              Fee[]
  journalEntryLines JournalLine[]
  payments          Payment[]
  paymentsSource    Payment[]      @relation("PaymentSource")
  paymentsDest      Payment[]      @relation("PaymentDest")
  payrolls          Payroll[]
  expenses          Expense[]
  employer          Employer?      @relation(fields: [employerId], references: [employerId])
  parent            Compte         @relation("CompteToParent", fields: [parentId], references: [id])
  children          Compte[]       @relation("CompteToParent")
  student           Student?       @relation(fields: [studentId], references: [studentId])
  translations      CompteTranslation[]

  @@map("comptes")
  @@index([tenantId])
}

model CompteTranslation {
  id        Int      @id @default(autoincrement())
  compteId  Int
  locale    String
  name      String
  compte    Compte   @relation(fields: [compteId], references: [id], onDelete: Cascade)

  @@unique([compteId, locale])
}

model Fee {
  id                    Int       @id @default(autoincrement())
  title                 String
  amount                Decimal   @default(0) @db.Decimal(15, 2)
  dueDate               DateTime
  classId               Int?
  studentId             Int?
  description           String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  compteId              Int?
  dateEndConsommation   DateTime?
  dateStartConsommation DateTime?

  tenantId              String
  version               Int       @default(1)
  operationId           String?   @unique

  class                 classes?  @relation(fields: [classId], references: [classId])
  compte                Compte?   @relation(fields: [compteId], references: [id])
  student               Student?  @relation(fields: [studentId], references: [studentId])
  payments              Payment[]

  @@index([tenantId])
}

model Payroll {
  id           Int           @id @default(autoincrement())
  employerId   Int
  period_start DateTime
  period_end   DateTime
  baseSalary   Decimal       @db.Decimal(10, 2)
  allowances   Decimal       @default(0) @db.Decimal(10, 2)
  deductions   Decimal       @default(0) @db.Decimal(10, 2)
  netSalary    Decimal       @db.Decimal(10, 2)
  status            PayrollStatus @default(DRAFT)
  attendanceSummary Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenantId          String
  version           Int           @default(1)
  operationId       String?       @unique

  employer          Employer      @relation(fields: [employerId], references: [employerId])
  compteId          Int?
  compte            Compte?       @relation(fields: [compteId], references: [id])

  @@index([tenantId])
}

model Expense {
  id          Int       @id @default(autoincrement())
  title       String
  category    String
  amount      Decimal   @db.Decimal(10, 2)
  expenseDate DateTime
  description String?
  isPaid      Boolean   @default(false)
  dateStartConsommation DateTime?
  dateEndConsommation   DateTime?
  isAmortization        Boolean   @default(false)
  compteId              Int?
  compte                Compte?   @relation(fields: [compteId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenantId    String
  version     Int       @default(1)
  operationId String?   @unique

  payments    Payment[]

  @@index([tenantId])
}

model Payment {
  id            Int           @id @default(autoincrement())
  feeId         Int?
  amount        Float
  date          DateTime      @default(now())
  method        PaymentMethod @default(CASH)
  status        PaymentStatus @default(COMPLETED)
  transactionId String?
  description   String?
  studentId     Int?
  employerId    Int?
  compteId      Int?
  compteSourceId Int?
  compteDestId   Int?
  expenseId     Int?

  tenantId      String
  version       Int           @default(1)
  operationId   String?       @unique

  compte        Compte?       @relation(fields: [compteId], references: [id])
  compteSource  Compte?       @relation("PaymentSource", fields: [compteSourceId], references: [id])
  compteDest    Compte?       @relation("PaymentDest", fields: [compteDestId], references: [id])
  employer      Employer?     @relation(fields: [employerId], references: [employerId])
  expense       Expense?      @relation(fields: [expenseId], references: [id])
  fee           Fee?          @relation(fields: [feeId], references: [id])
  student       Student?      @relation(fields: [studentId], references: [studentId])

  @@index([studentId])
  @@index([employerId])
  @@index([date])
  @@index([tenantId])
}

model Journal {
  id        Int            @id @default(autoincrement())
  code      String         @unique
  name      String
  type      JournalType
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  createdBy Int

  tenantId  String
  version   Int            @default(1)
  operationId String?      @unique

  entries   JournalEntry[]

  @@map("journals")
  @@index([tenantId])
}

model JournalEntry {
  id            Int                @id @default(autoincrement())
  journalId     Int
  entryNumber   String             @unique
  date          DateTime           @default(now())
  referenceType String?
  referenceId   Int?
  description   String?
  totalDebit    Decimal            @default(0) @db.Decimal(15, 2)
  totalCredit   Decimal            @default(0) @db.Decimal(15, 2)
  status        JournalEntryStatus @default(DRAFT)
  createdAt     DateTime           @default(now())
  postedAt      DateTime?
  createdBy     Int
  postedBy      Int?

  tenantId      String
  version       Int                @default(1)
  operationId   String?            @unique

  journal       Journal            @relation(fields: [journalId], references: [id])
  lines         JournalLine[]

  @@index([date])
  @@index([tenantId])
}

model JournalLine {
  id          Int          @id @default(autoincrement())
  entryId     Int
  compteId    Int
  lineNumber  Int
  debit       Decimal      @default(0) @db.Decimal(15, 2)
  credit      Decimal      @default(0) @db.Decimal(15, 2)
  description String?

  tenantId    String
  version     Int          @default(1)
  operationId String?      @unique

  compte      Compte       @relation(fields: [compteId], references: [id])
  entry       JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([compteId])
  @@index([tenantId])
}

model FiscalYear {
  id        Int      @id @default(autoincrement())
  year      String   @unique
  startDate DateTime
  endDate   DateTime
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum PayrollStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  REVERSED
  CANCELLED
}

enum AccountNature {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum JournalType {
  CASH
  BANK
  PAYROLL
  GENERAL
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  ONLINE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum CompteCategory {
  GENERAL
  CAISSE
  BANQUE
  RECETTE
  DEPENSE
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId    String
  version     Int      @default(1)
  operationId String?  @unique
  isPublic    Boolean  @default(true)

  @@map("events")
  @@index([tenantId])
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

model StudentRiskProfile {
  id                 Int       @id @default(autoincrement())
  studentId          Int       @unique
  attendance         Float     @default(0)
  averageGrade       Float     @default(0)
  behaviorScore      Float     @default(0)
  homeworkCompletion Float     @default(0)
  riskLevel          RiskLevel @default(LOW)
  recommendation     String?
  lastCalculatedAt   DateTime  @default(now())

  tenantId           String
  version            Int       @default(1)
  operationId        String?   @unique

  student            Student   @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@index([tenantId])
}

model TeacherEvaluation {
  id                     Int      @id @default(autoincrement())
  teacherId              Int
  score                  Float
  improvementProbability Float
  weakAreas              String[]
  trainingPlan           String[]
  createdAt              DateTime @default(now())
  
  teacher                Employer @relation(fields: [teacherId], references: [employerId])
  
  tenantId               String

  @@index([teacherId])
  @@index([tenantId])
}

enum TimetableMode {
  MANUAL
  AI_GENERATED
}

model SystemSettings {
  id            Int      @id @default(1)
  weekStartDay  WeekDay  @default(SUNDAY)
  firstHour     String   @default("08:00")
  lastHour      String   @default("16:00")
  slotDuration  Int      @default(60)

  tenantId      String
  version       Int      @default(1)
  operationId   String?  @unique

  @@index([tenantId])
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}
