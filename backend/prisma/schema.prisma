generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  username String @unique
  password String
  role     Role
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model Student {
  studentId       Int      @id @default(autoincrement())
  firstName       String
  lastName        String
  dateOfBirth     DateTime
  gender          String
  address         String?
  parentId        Int
  code            String   @unique
  health          String?
  dateCreate      DateTime @default(now())
  dateModif       DateTime @updatedAt
  lieuOfBirth     String?
  bloodType       String?
  etatCivil       String?
  cid             String?
  nationality     String?
  observation     String?
  numNumerisation String?
  dateInscription DateTime
  okBlock         Boolean  @default(false)

  // Change from photo Bytes? to photoFileName String?
  photoFileName String? // Store filename instead of binary data

  // Relations
  parent Parent @relation(fields: [parentId], references: [parentId], onDelete: Cascade)

  studentClasses    StudentClass[]
  studentAttendance StudentAttendance[]
  fees              Fee[]
  payments          Payment[]
  compte            Compte?

  @@map("students")
}

model Parent {
  parentId     Int     @id @default(autoincrement())
  father       String?
  mother       String?
  fatherJob    String?
  motherJob    String?
  fatherNumber String?
  motherNumber String?

  // Relations
  students Student[]

  @@map("parents")
}

model Local {
  localId    Int       @id @default(autoincrement())
  name       String
  code       String    @unique
  dateCreate DateTime?
  dateModif  DateTime?
  NumClass   Int?
  size       Int       @default(0) // Added for capacity check

  classes       classes[]
  subject_local subject_local[]
}

model classes {
  classId    Int       @id @default(autoincrement())
  ClassName  String
  code       String    @unique
  dateCreate DateTime?
  dateModif  DateTime?
  NumStudent Int
  localId    Int
  okBlock    String    @default("N")
  cloture    Boolean   @default(false)

  TeacherCalsses    TeaherClass[]
  Timetables        Timetable[]
  studentAttendance StudentAttendance[]
  studentClasses    StudentClass[]
  fees              Fee[]

  local Local @relation(fields: [localId], references: [localId])
}

model subject {
  subjectId   Int       @id @default(autoincrement())
  subjectName String
  totalGrads  Float
  parentId    Int
  BG          Int
  BD          Int
  level       Int?
  dateCreate  DateTime?
  dateModif   DateTime?
  okBlock     Boolean   @default(false)

  parent          subject?         @relation("SubjectToParent", fields: [parentId], references: [subjectId])
  children        subject[]        @relation("SubjectToParent")
  subject_local   subject_local[]
  Teachersubjects TeacherSubject[]
  Timetables      Timetable[]
  grads Grads[]
}

model parameter {
  paramId   Int     @id @default(autoincrement())
  paramName String  @unique
  okActive  Boolean @default(false)
}

model subject_local {
  subjectLocalId Int       @id @default(autoincrement())
  subjectId      Int
  localId        Int
  cloture        Boolean   @default(false)
  dateCreate     DateTime?
  dateModif      DateTime?

  subject subject @relation(fields: [subjectId], references: [subjectId])
  local   Local   @relation(fields: [localId], references: [localId])

  @@unique([subjectId, localId])
}

model StudentClass {
  id           Int      @id @default(autoincrement())
  studentId    Int
  classId      Int
  schoolYearId Int
  isCurrent    Boolean  @default(false)
  cloture      Boolean  @default(false) // Added for transition tracking

  // Relations
  Student    Student    @relation(fields: [studentId], references: [studentId])
  Class      classes    @relation(fields: [classId], references: [classId])
  schoolYear SchoolYear @relation(fields: [schoolYearId], references: [id])

  grads Grads[]

  @@unique([studentId, schoolYearId]) 
  @@map("student_classes")
}

model SchoolYear {
  id             Int            @id @default(autoincrement())
  year           String         @unique // e.g. "2024-2025"
  startDate      DateTime
  endDate        DateTime
  isCurrent      Boolean        @default(false)
  studentClasses StudentClass[]

  @@map("school_years")
}

model Employer {
  employerId      Int       @id @default(autoincrement())
  firstName       String
  lastName        String
  dateOfBirth     DateTime
  lieuOfBirth     String?
  gender          String
  address         String?
  fatherName      String?
  motherName      String?
  code            String    @unique
  health          String?
  dateCreate      DateTime?
  dateModif       DateTime?
  bloodType       String?
  etatCivil       String?
  cid             String?
  phone           String?
  nationality     String?
  observation     String?
  numNumerisation String?
  dateInscription DateTime?
  okBlock         Boolean   @default(false)
  type            String
  weeklyWorkload  Int       @default(20)

  // Change from photo Bytes? to photoFileName String?
  photoFileName String? // Store filename instead of binary data

  TeacherCalsses     TeaherClass[]
  Teachersubjects    TeacherSubject[]
  Timetables         Timetable[]
  employerAttendance EmployerAttendance[]
  fees               Fee[]
  payments           Payment[]
  compte             Compte?

  @@map("employers")
}

model TeaherClass {
  id         Int     @id @default(autoincrement())
  employerId Int
  classId    Int
  isCurrent  Boolean @default(false) // Optional helper field

  Employer Employer @relation(fields: [employerId], references: [employerId])
  Class    classes  @relation(fields: [classId], references: [classId])

  @@unique([employerId]) // One local per student per year
}

model TeacherSubject {
  id         Int     @id @default(autoincrement())
  employerId Int
  subjectId  Int
  isCurrent  Boolean @default(false) // Optional helper field

  Employer Employer @relation(fields: [employerId], references: [employerId])
  subject  subject  @relation(fields: [subjectId], references: [subjectId])

  @@unique([employerId, subjectId]) // One local per student per year
}

model TimeSlot {
  id        Int      @id @default(autoincrement())
  label     String
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Timetables Timetable[]
}

model Timetable {
  id           Int    @id @default(autoincrement())
  day          String // e.g. "Monday"
  classId      Int
  subjectId    Int
  timeSlotId   Int
  employerId   Int?
  academicYear String

  Class    classes  @relation(fields: [classId], references: [classId])
  subject  subject  @relation(fields: [subjectId], references: [subjectId])
  timeSlot TimeSlot @relation(fields: [timeSlotId], references: [id])
  teacher  Employer? @relation(fields: [employerId], references: [employerId])

  @@unique([day, timeSlotId, classId, academicYear])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model StudentAttendance {
  id        Int              @id @default(autoincrement())
  studentId Int
  classId   Int
  date      DateTime         @default(now())
  status    AttendanceStatus @default(ABSENT)

  academicYear String

  student Student @relation(fields: [studentId], references: [studentId])
  class   classes @relation(fields: [classId], references: [classId])

  @@unique([studentId, date, academicYear])
}

model EmployerAttendance {
  id           Int              @id @default(autoincrement())
  employerId   Int
  date         DateTime         @default(now())
  checkInTime  DateTime?
  checkOutTime DateTime?
  status       AttendanceStatus @default(ABSENT)
  remarks      String?
  academicYear String

  employer Employer @relation(fields: [employerId], references: [employerId])

  @@unique([employerId, date, academicYear])
}

model Exam {
  id         Int       @id @default(autoincrement())
  examName   String
  dateStart  DateTime
  dateEnd    DateTime
  publish    Boolean
  dateCreate DateTime?
  dateModif  DateTime?

  grads Grads[]
}

model Grads {
  id             Int       @id @default(autoincrement())
  grads          Float
  dateCreate     DateTime?
  dateModif      DateTime?
  examId         Int
  studentClassId Int
  subjectId      Int

  exam          Exam          @relation(fields: [examId], references: [id])
  studentClass  StudentClass  @relation(fields: [studentClassId], references: [id])
  subject       subject       @relation(fields: [subjectId], references: [subjectId])

  @@unique([examId, studentClassId, subjectId]) 
  @@map("grads")  
}

model Compte {
  id          Int       @id @default(autoincrement())
  name        String
  parentId    Int
  BG          Int
  BD          Int
  level       Int?
  dateCreate  DateTime? @default(now())
  dateModif   DateTime? @updatedAt
  okBlock     Boolean   @default(false)

  parent      Compte?   @relation("CompteToParent", fields: [parentId], references: [id])
  children    Compte[]  @relation("CompteToParent")
  
  fees        Fee[]
  payments    Payment[]
  employerId  Int?      @unique
  employer    Employer? @relation(fields: [employerId], references: [employerId])
  studentId   Int?      @unique
  student     Student?  @relation(fields: [studentId], references: [studentId])

  @@map("comptes")
}

model Fee {
  id          Int      @id @default(autoincrement())
  type        String   @default("income") // "income" or "expense"
  title       String
  amount      Float
  dueDate     DateTime
  classId     Int?     // Optional: if fee applies to a whole class
  studentId   Int?     // Optional: if fee applies to a specific student
  employerId  Int?     // Optional: for expense fees
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  class       classes?  @relation(fields: [classId], references: [classId])
  student     Student?  @relation(fields: [studentId], references: [studentId])
  employer    Employer? @relation(fields: [employerId], references: [employerId])
  compteId    Int?
  compte      Compte?   @relation(fields: [compteId], references: [id])
  payments    Payment[]
}

model Payment {
  id            Int           @id @default(autoincrement())
  feeId         Int?
  amount        Float
  date          DateTime      @default(now())
  method        PaymentMethod @default(CASH)
  status        PaymentStatus @default(COMPLETED)
  transactionId String?
  description   String?

  fee           Fee?     @relation(fields: [feeId], references: [id])
  studentId     Int?
  student       Student? @relation(fields: [studentId], references: [studentId])
  employerId    Int?
  employer      Employer? @relation(fields: [employerId], references: [employerId])
  compteId      Int?
  compte        Compte?  @relation(fields: [compteId], references: [id])
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  ONLINE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ExpenseType {
  SALARY
  BILL
  EQUIPMENT
  MAINTENANCE
  OTHER
}
