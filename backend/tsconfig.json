{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ESNext",
    "outDir": "./dist",
    "rootDir": "src",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "declaration": true,
    "removeComments": true,
    "baseUrl": "./",
    "types": ["node", "jest", "multer"],
    "paths": {
      "prisma/*": ["src/prisma/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "test", "dist"]
}
